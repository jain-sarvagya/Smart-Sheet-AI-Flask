# Flask Configuration
FLASK_APP=run.py
FLASK_DEBUG=True
FLASK_ENV=development
SECRET_KEY=dev_secret_key_change_in_production
JWT_SECRET_KEY=dev_jwt_secret_key_change_in_production

# Database Configuration
# Defaults to PostgreSQL, will fall back to SQLite (sqlite:///smart_sheet.db) if database is unavailable
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_sheet

# AI Configuration
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_google_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ImageKit Configuration (Optional, fallback to local storage if empty)
# Set up a free account at https://imagekit.io
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# File Upload Limit (Default: 16MB)
MAX_CONTENT_LENGTH=104857600
UPLOAD_FOLDER=uploads
